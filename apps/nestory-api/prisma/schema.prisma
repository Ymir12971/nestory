generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Schema 详细定义见 docs/dev/04_Nestory_数据库设计v1.7.md
// 此处先放占位 user model，避免 prisma generate 失败
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
