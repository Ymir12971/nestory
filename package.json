{
  "name": "nestory",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "strip-icc": "node scripts/strip-icc.mjs",
    "demo": "node scripts/start-demo.mjs",
    "dev": "turbo run dev --filter='./apps/nestory-api' --filter='./apps/nestory-web'",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  }
}
